# Copy to .env. Default = your local Ollama: no key, no money, no internet.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL=ministral-3:8b

# To call a frontier model instead, comment the three lines above and use:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key
# MODEL=gpt-4.1-mini
