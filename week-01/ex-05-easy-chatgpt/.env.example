# Copy this file to .env (never commit .env — it is in .gitignore).
# Defaults point at the HOST's Ollama, reached from inside Docker via
# host.docker.internal (NOT localhost, which would be the container itself).
#
# IMPORTANT: MODEL must be a model your HOST's Ollama actually serves —
# check with `ollama list`. Here it is llama3.2:3b.

OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
MODEL=llama3.2:3b

# To use a cloud model instead, change only these three lines, e.g.:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-your-key
# MODEL=some-model
